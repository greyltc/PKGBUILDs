# U-Boot: Raspberry Pi

pkgname=uboot-raspberrypi
pkgver=2026.07
pkgrel=1
pkgdesc="U-Boot for Raspberry Pi"
arch=('aarch64')
url='https://docs.u-boot.org/en/latest'
license=('GPL')
backup=('boot/boot.txt' 'boot/boot.scr' 'boot/config.txt')
makedepends=('bc' 'dtc' 'git' 'util-linux')
source=(
        "https://github.com/u-boot/u-boot/archive/refs/tags/v${pkgver/rc/-rc}.tar.gz"
        '0001-rpi-increase-space-for-kernel.patch'
        '0002-fix-serial-console.patch'
        'boot.txt.v3'
        'mkscr')
b2sums=('0af0aec520ccc098c24ae65cebf61f8c89d708a13228059d30087b53c558ef2708594ec1e09c9cff7c88d111ebe99317edd159c8456636ece3fd8d75fca46387'
        'fb70aabde822f5633b200d4a27adcb12fbfb6fb0b628749ffba263cbce5f523bb83091900c77ef7272ee436409c73e37fb17bc55cd70b84dd7d7d63971bae924'
        '9e6c8c571a1522a1f4d5cac0212f921ca7090122a80c5bf1e6eb9fa8065f1df491b6b56b232215b1c69d0d96a88e5d397dea50f5e37c6aec785f15e401b4e4df'
        '4c4df2efb5f17c53ce35c012c082096ee9535548443c5f041193ac18063649bd6afa69a3b998154fdc278dd5131e150b0b019885c99b6eb1cd0a720d65dcdd98'
        '4ea782264696aa85e30847413088bd338e2beb2ec4e57c2808f80af28ac613ab4ae82b37eb0ff902e66f8a12082a1f9a546bbf20dfeb4c43f59f465987043ede')

prepare() {
  cd u-boot-${pkgver/rc/-rc}

  #patch -p1 -i ../0001-rpi-increase-space-for-kernel.patch
  #patch -p1 -i ../0002-fix-serial-console.patch
}

build() {
  cd u-boot-${pkgver/rc/-rc}

  unset CFLAGS
  unset CXXFLAGS
  unset CPPFLAGS

  make distclean
  make rpi_arm64_config
  echo 'CONFIG_IDENT_STRING=" Arch Linux"' >> .config
  make EXTRAVERSION=-${pkgrel}
}

package() {
  cd u-boot-${pkgver/rc/-rc}

  mkdir -p "${pkgdir}"/boot

  cp u-boot.bin "${pkgdir}/boot/".
  #cp u-boot.bin ${pkgdir}/boot/kernel8.img
  cp ../boot.txt.v3 ../boot.txt

  echo "enable_uart=1" > "${pkgdir}/boot/"config.txt
  tools/mkimage -A arm -O linux -T script -C none -n "Das U-Boot script" -d ../boot.txt "${pkgdir}"/boot/boot.scr
  cp ../{boot.txt,mkscr} "${pkgdir}"/boot
}
